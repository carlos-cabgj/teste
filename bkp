import time

from picamera2.encoders import H264Encoder
from picamera2.outputs import FileOutput

from src.services.ServiceAbstract import ServiceAbstract
from src.services.system.GateService import GateService
from src.services.system.DirectorySampleService import DirectorySampleService
from src.services.PatternService import PatternService, SOBEL_THRESHOLD, MATCH_THRESHOLD
from src.services.LogService import LogService as Log
from src.config.Configuration import Configuration as config

class RunSampleService (ServiceAbstract):
    def __init__(self, caller, conveyor):
        self.conveyorService = conveyor
        self.globalConfig = config().configSocket
        self.caller = caller

        self.interrupt = False
        self.directorySampleService = DirectorySampleService()

        self.patternService = PatternService(camera=self.caller)

        self.gateService = GateService()
        self.optionExecute = 'perTime'

    def execute(self, sample_id, class_id, options):

        self.interrupt == False

        if self.optionExecute == 'perTime' :
            Log('Process send everything perTime {0}'.format(time.strftime('%Y%m%d %H-%M-%S')))
            return self.executePerTime(sample_id, class_id, options)
        else :
            Log('Process send everything perTrack {0}'.format(time.strftime('%Y%m%d %H-%M-%S')))
            return self.executeTrack(sample_id, class_id, options)

    def executeTrack(self, sample_id, class_id, options):

        self.interrupt = False
        self.sample_id = sample_id
        self.class_id = class_id

        encoder = H264Encoder(10000000)
        output = FileOutput("/dev/null")

        samplesCount = 0
        timeConveyor = 0.5
        timeConveyorTotal = 4
        timeConveyorTotalCount = 0
        samplesLimit = config().photosSendingConfig['maxSendingSamples']
        maxDuration = float(options.get('trackDuration', 30))
        sobelThreshold = int(options.get('sobelThreshold', SOBEL_THRESHOLD))
        matchThreshold = float(options.get('matchThreshold', MATCH_THRESHOLD))
        startTime = time.time()
        frameIdx = 0
        objectCaptured = False

        Log('Start sending process {0}'.format(time.strftime('%Y%m%d %H-%M-%S')))

        self.patternService.reset()
        self.caller.start_recording(encoder, output, name='main')

        try:
            while (
                time.time() - startTime < maxDuration
                and samplesCount < samplesLimit
                and self.interrupt == False
            ):
                frame = self.caller.capture_array()

                detection = self.patternService.process_frame(
                    frame,
                    sobel_threshold=sobelThreshold,
                    match_threshold=matchThreshold,
                    frame_idx=frameIdx
                )

                if detection['event'] == 'pattern_saved':
                    Log('Padrao salvo no ROI inicial')

                if detection['should_capture'] and objectCaptured == False or timeConveyorTotalCount >= timeConveyorTotal:
                    Log('Padrao detectado no ROI final - similaridade {0:.2%}'.format(
                        detection['similarity']
                    ))

                    if self.takePhoto(checkGrains=False):
                        samplesCount += 1
                        objectCaptured = True
                        Log('Imagem Capturada {0}/{2} - {1}'.format(
                                samplesCount,
                                time.strftime('%Y%m%d'),
                                samplesLimit
                            )
                        )

                    timeConveyorTotalCount = 0

                elif objectCaptured and self.patternService.pattern_in_final == False:
                    self.patternService.reset()
                    objectCaptured = False

                print('RunSample -> Moving...')
                self.conveyorService.start()
                time.sleep(timeConveyor)
                self.conveyorService.stop()
                timeConveyorTotalCount = timeConveyorTotalCount + timeConveyor

                frameIdx += 1
        finally:
            stopRecording = getattr(self.caller, 'stop_recording', None)
            if stopRecording:
                stopRecording()
            elif hasattr(self.caller, 'cam'):
                self.caller.cam.stop_recording()

            stopCamera = getattr(self.caller, 'stop', None)
            if stopCamera:
                stopCamera()
            elif hasattr(self.caller, 'cam'):
                self.caller.cam.stop()

        folderPath = self.directorySampleService.getFolderPicture(self.sample_id)
        sampleDirectory = self.directorySampleService.decodeFolderName(folderPath)
        self.directorySampleService.updFolderStatusNotSend(sampleDirectory)

        Log('Process send everything {0}'.format(time.strftime('%Y%m%d %H-%M-%S')))

        return samplesCount

    def executePerTime(self, sample_id, class_id, options):

        self.interrupt == False

        if 'samplesTimeConveyor' in options :
            timeConveyor = float(options['samplesTimeConveyor'])
        else :
            timeConveyor = 3.1

        samplesCount = 0
        samplesIsValid = True
        samplesLimit = config().photosSendingConfig['maxSendingSamples']

        Log('Start sending process {0}'.format(time.strftime('%Y%m%d %H-%M-%S')))

        self.sample_id = sample_id
        self.class_id = class_id

        while samplesIsValid and samplesCount < samplesLimit and self.interrupt == False :
            if self.runOneSample(timeConveyor, samplesCount) :
                Log('Imagem Capturada {0}/{2} - {1}'.format(
                        samplesCount,
                        time.strftime('%Y%m%d'),
                        samplesLimit
                    )
                )
                break

        folderPath = self.directorySampleService.getFolderPicture(self.sample_id)
        sampleDirectory = self.directorySampleService.decodeFolderName(folderPath)
        self.directorySampleService.updFolderStatusNotSend(sampleDirectory)

        Log('Process send everything {0}'.format(time.strftime('%Y%m%d %H-%M-%S')))

        return samplesCount

    def loop (self, timeConveyor, samplesCount) :
        pass

    def takePhoto (self, checkGrains=False) :
        dataCamera = self.caller.take_picture(checkGrains)
        print(dataCamera)
        if dataCamera == False :
            return False

        self.directorySampleService.savePictureInFolder(
            dataCamera['data'],
            dataCamera['metadata'],
            self.sample_id
        )

    def runOneSample (self, timeConveyor, samplesCount) :
        self.gateService.open()
        self.conveyorService.start()
        time.sleep(timeConveyor)
        self.conveyorService.stop()
        Log('Preparando foto')
        time.sleep(0.3)

        checkGrains = True

        if samplesCount > 0 and samplesCount <= 7 :
            checkGrains = False

        #TODO remove befor commit
        # checkGrains = False

        self.takePhoto()

        samplesCount = samplesCount + 1

        self.gateService.close()
        Log('Stored {0}'.format(samplesCount))
        return True

    def cancel(self):
        self.interrupt = True


