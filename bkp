    def capture_array(self, name="main"):
        ok, frame = self.video.read()

        if not ok:
            self.video.set(cv2.CAP_PROP_POS_FRAMES, 0)
            ok, frame = self.video.read()

        frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        size = (1920, 1080) if name == "lores" else (4608, 2592)
        return cv2.resize(frame, size)

    def capture_file(self, output, name='main', format=None):
        filepath = 'etc/grains_sample-small.jpg'
        originalImg = open(filepath, 'rb')
        with tempfile.NamedTemporaryFile() as tmp:
            print(tmp.name)
            tmp.write(originalImg.read())
            img = self.writeText(Image.open(tmp.name))
            byte_io = BytesIO()
            img.save(byte_io, 'PNG')
            output.write(byte_io.getvalue())
        return output

    def writeText(self, img):
        timestamp = time.time()
        font = ImageFont.truetype('etc/arial.ttf', 12)
        draw = ImageDraw.Draw(img)
        draw.text((img.width/2,img.height/2), '-> {0}'.format(timestamp), font=font)
        return img
