from src.helpers.Picamera2Fake import Picamera2

class CameraService():
    def __init__(self, config = None):
        self.cancelPostFileInChunks = False
        self.configCamera()

    def configCamera(self):
        self.cam = Picamera2()
        self.capture_config = self.cam.create_still_configuration(
            main={"size": (4608, 2592)},
            lores={"format": "RGB888", "size": (1920, 1080)}
        )
        self.cam.options['quality'] = 100
        self.cam.configure(self.capture_config)
        self.cam.start()
        self.configCam = config().cameraControlConfig
        self.cam.set_controls(self.configCam)
        pass

    def configOldCamera(self):
        pass

    def decode_image(self, data):
        data.seek(0)
        file_bytes = np.asarray(bytearray(data.read()), dtype=np.uint8)
        decoded_image = cv.imdecode(file_bytes, cv.IMREAD_COLOR)
        return decoded_image

    def encode_image(self, image):
        _, im_buf_arr = cv.imencode(".jpg", image)
        data = io.BytesIO(im_buf_arr)
        return data

    def cut_image(self, image):
        LEFT_SIDE_LIMIT, RIGHT_SIDE_LIMIT = 215, 3750
        UP_SIDE_LIMIT, DOWN_SIDE_LIMIT = 120, 2350
        return image[UP_SIDE_LIMIT:DOWN_SIDE_LIMIT, LEFT_SIDE_LIMIT:RIGHT_SIDE_LIMIT]

    def resize_image(self, image):
        h, w, d = image.shape
        resized_img = cv.resize(image, (w//2, h//2))
        return resized_img

    def segmentation(self, image):
        hsv_image = cv.cvtColor(image, cv.COLOR_BGR2HSV)
        hsv_image = cv.medianBlur(hsv_image,11)
        mask = cv.inRange(hsv_image, (105, 0, 120), (125, 255, 255))
        mask = cv.bitwise_not(mask)
        mask = cv.morphologyEx(mask, cv.MORPH_OPEN, np.ones((15,15), np.uint8))
        countPixels = cv.countNonZero(mask)
        if countPixels >= 20000: return True
        return False

    def start_recording(self, encoding, output, name='main'):
        return self.cam.start_recording(encoding, output, name=name)

    def stop_recording(self):
        return self.cam.stop_recording()

    def stop(self):
        return self.cam.stop()

    def capture_array(self, name='main'):
        return self.cam.capture_array(name)

    def take_picture(self, checkGrains = True) -> io.BytesIO:
        data = io.BytesIO()
        self.cam.capture_file(data, name='main', format='jpeg')

        image = self.decode_image(data)
        cutted_image = self.cut_image(image)

        if checkGrains:
            resized_image = self.resize_image(cutted_image)
            hasGrains = self.segmentation(resized_image)
            if hasGrains == False:
                return False

        data = self.encode_image(cutted_image)
        metadata = self.cam.capture_metadata()
        return {'data' : data, 'metadata' : metadata}

    def system_exec_init(self, initLevel : int) -> None:
        subprocess.call(['init', str(initLevel)])

    def get_trace(self, e : BaseException) -> list:
        trace = []
        tb = e.__traceback__
        while tb is not None:
            trace.append('{0}:{1}'.format(tb.tb_frame.f_code.co_filename, tb.tb_lineno))
            tb = tb.tb_next

        return trace




